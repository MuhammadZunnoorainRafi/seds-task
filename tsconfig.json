{
  "compilerOptions": {
    "target": "ES2020",
    "outDir": "./build",
    "strict": true,
    "module": "ES2020",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["node_modules/@types", "@types"]
  }
}
